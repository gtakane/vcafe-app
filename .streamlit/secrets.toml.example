# Streamlit Community Cloud にデプロイする場合、このファイルの内容を
# Streamlit Cloud の Settings > Secrets に貼り付けてください。
# このファイル自体は .gitignore で管理外にしてください（secrets_local.json と同様）。

discord_bot_token  = "（Discordボットトークン）"
discord_channel_id = "1489926976239304734"

# Firebase サービスアカウントキーの内容を直接 TOML テーブルとして記述します
# serviceAccountKey.json の中身をそのまま各フィールドに展開してください
[firebase_key_json]
type                        = "service_account"
project_id                  = "v-athome-cafe-app"
private_key_id              = "（private_key_id）"
private_key                 = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
client_email                = "（client_email）"
client_id                   = "（client_id）"
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "（client_x509_cert_url）"
universe_domain             = "googleapis.com"
